# --- Database (Payload uses this Postgres connection) ---
DATABASE_URL=postgres://user:password@localhost:5432/a2s

# --- Payload ---
# Long random string used to sign/encrypt tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI (OpenRouter via Vercel AI SDK) ---
OPENROUTER_API_KEY=

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash / Workflow (async story generation) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
