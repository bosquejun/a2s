# --- Database (Payload uses this Postgres connection) ---
DATABASE_URL=postgres://user:password@localhost:5432/a2s

# --- Payload ---
# Long random string used to sign/encrypt tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI (OpenRouter via Vercel AI SDK) ---
OPENROUTER_API_KEY=

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash / Workflow (async whisper review) ---
# Only used by the reader-submission ("whisper") path. Not needed when
# NEXT_PUBLIC_FEATURE_WHISPER is off.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Cloudflare R2 (S3-compatible media storage) ---
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Story ingest (POST /api/stories/ingest) ---
# Bearer secret the Claude generation routine uses to publish stories.
# Generate with: openssl rand -hex 32.
STORY_GENERATION_SECRET=

# --- Facebook Page connection (browser OAuth) ---
# App-level credentials from your Meta app (developers.facebook.com). The
# per-Page access token is obtained via the "Connect Facebook Page" button in
# the Payload admin and stored (encrypted) in the database — not here.
# OAuth redirect URI to register: ${NEXT_PUBLIC_SITE_URL}/api/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- X (Twitter) account connection (browser OAuth 2.0 / PKCE) ---
# OAuth 2.0 Client ID/Secret from your X app (developer.x.com), configured as a
# confidential client with "tweet.write" access. The per-account access/refresh
# tokens are obtained via the "Connect X Account" button in the Payload admin
# and stored (encrypted) in the database — not here.
# OAuth redirect URI (callback) to register: ${NEXT_PUBLIC_SITE_URL}/api/x/callback
#
# Alternatively, the admin offers a "Connect manually with API keys" fallback
# that takes the four long-lived OAuth 1.0a credentials (API Key/Secret +
# Access Token/Secret) straight from the X app's "Keys and tokens" tab — no
# X_CLIENT_ID/SECRET or redirect URI required for that path.
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Threads (Meta) account connection (browser OAuth) ---
# App-level credentials from your Threads app (developers.facebook.com → "Use
# cases: Threads API"). The Threads API is free — no paid tier or per-post
# charge; production posting just requires Meta App Review for the
# threads_content_publish permission. The long-lived (≈60-day) per-account token
# is obtained via the "Connect Threads Account" button in the Payload admin and
# stored (encrypted) in the database — not here. It auto-refreshes before expiry.
# OAuth redirect URI (callback) to register: ${NEXT_PUBLIC_SITE_URL}/api/threads/callback
THREADS_APP_ID=
THREADS_APP_SECRET=

# --- Feature flags ---
# Reader story submissions ("whisper") flow: /write, /track, the write API, and
# all entry-point links. Off unless set to exactly "true".
NEXT_PUBLIC_FEATURE_WHISPER=false
# Posting stories to X (Twitter). Off by default because X charges per post
# (pay-per-use; no free tier). Set to exactly "true" to re-enable auto-post and
# the manual "Share to X" button once the X developer account is funded.
NEXT_PUBLIC_FEATURE_X_POSTING=false
